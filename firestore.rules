rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnerByField(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    // users/{uid}
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // profiles/{uid}
    match /profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // products/{productId}
    match /products/{productId} {
      allow create: if isOwnerByField(request.resource.data);
      allow read, update, delete: if isOwnerByField(resource.data);
    }

    // generatedAds/{adId}
    match /generatedAds/{adId} {
      allow create: if isOwnerByField(request.resource.data);
      allow read, update, delete: if isOwnerByField(resource.data);
    }

    // khataEntries/{entryId}
    match /khataEntries/{entryId} {
      allow create: if isOwnerByField(request.resource.data);
      allow read, update, delete: if isOwnerByField(resource.data);
    }

    // transactions/{txId}
    match /transactions/{txId} {
      allow create: if isOwnerByField(request.resource.data);
      allow read, update, delete: if isOwnerByField(resource.data);
    }

    // usageEvents/{eventId}
    match /usageEvents/{eventId} {
      allow create: if isOwnerByField(request.resource.data);
      allow read, update, delete: if isOwnerByField(resource.data);
    }

    // inquiries/{inquiryId}
    match /inquiries/{inquiryId} {
      allow create: if isOwnerByField(request.resource.data);
      allow read, update, delete: if isOwnerByField(resource.data);
    }

    // orderSlips/{slipId}
    match /orderSlips/{slipId} {
      allow create: if isOwnerByField(request.resource.data);
      allow read, update, delete: if isOwnerByField(resource.data);
    }
  }
}
